# ===========================================
# CondoCompare - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# Different sections for local dev vs production

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
# Local: docker-compose provides PostgreSQL
# Production: Use Supabase connection string
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=condocompare
POSTGRES_USER=condocompare
POSTGRES_PASSWORD=your_secure_password_here

# ===========================================
# REDIS
# ===========================================
# Local: docker-compose provides Redis
# Production (Render): Auto-configured via render.yaml
# Production (Upstash): Use REDIS_URL
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# STORAGE (S3-Compatible)
# ===========================================
# Local: MinIO via docker-compose
# Production: Supabase Storage (S3-compatible endpoint)
#   MINIO_ENDPOINT=https://<project-id>.supabase.co/storage/v1/s3
#   MINIO_ACCESS_KEY=<supabase-service-role-key>
#   MINIO_SECRET_KEY=<supabase-service-role-key>
#   MINIO_REGION=<your-supabase-region>
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=condocompare-docs
MINIO_REGION=us-east-1

# ===========================================
# RABBITMQ (Message Queue)
# ===========================================
# Local: docker-compose provides RabbitMQ
# Production: CloudAMQP free tier or disable
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=condocompare
RABBITMQ_PASSWORD=condocompare123

# ===========================================
# BACKEND (Spring Boot)
# ===========================================
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
# Production: SPRING_PROFILES_ACTIVE=prod

# JWT - MUST change in production!
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_min_256_bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# CORS - comma-separated allowed origins
# Production: https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# ===========================================
# EMAIL (SMTP)
# ===========================================
# Local: Can use Mailtrap or MailHog for testing
# Production: Use Gmail, SendGrid, or Amazon SES
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@condocompare.com.br
MAIL_FROM_NAME=CondoCompare

# ===========================================
# STRIPE (Payments)
# ===========================================
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# APP
# ===========================================
FRONTEND_URL=http://localhost:3000

# ===========================================
# IA SERVICE (FastAPI + Groq)
# ===========================================
IA_SERVICE_PORT=8000
IA_SERVICE_URL=http://localhost:8000
ENVIRONMENT=development
# Production: ENVIRONMENT=production

# Groq API Key (required for IA features)
# Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ===========================================
# FRONTEND (Next.js)
# ===========================================
# These are set in Vercel dashboard for production
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_IA_URL=http://localhost:8000/api/v1
NODE_ENV=development

# ===========================================
# PRODUCTION QUICK REFERENCE
# ===========================================
# Vercel (Frontend):
#   NEXT_PUBLIC_API_URL=https://condocompare-backend.onrender.com/api/v1
#   NEXT_PUBLIC_IA_URL=https://condocompare-ia.onrender.com/api/v1
#
# Render (Backend):
#   SPRING_PROFILES_ACTIVE=prod
#   JWT_SECRET=<generated-strong-secret>
#   CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
#   Database/Redis auto-configured via render.yaml
#
# Render (IA Service):
#   ENVIRONMENT=production
#   GROQ_API_KEY=<your-groq-key>
#   CORS_ORIGINS=["https://your-app.vercel.app","https://condocompare-backend.onrender.com"]
#
# Render (Email):
#   MAIL_HOST=smtp.gmail.com (or SendGrid/SES)
#   MAIL_USERNAME=<your-email>
#   MAIL_PASSWORD=<app-password>
#   MAIL_FROM=noreply@condocompare.com.br
#   FRONTEND_URL=https://your-app.vercel.app
#
# Render (Stripe):
#   STRIPE_API_KEY=sk_live_<your-live-key>
#   STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>
#
# Supabase:
#   1. Create project at supabase.com
#   2. Go to Settings > Database > Connection string
#   3. Use host/port/user/password in Render env vars
#   4. For Storage: Settings > API > S3 Access Keys
