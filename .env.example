# ===========================================
# CondoCompare - Environment Variables
# ===========================================

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=condocompare
POSTGRES_USER=condocompare
POSTGRES_PASSWORD=your_secure_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO (S3 Compatible Storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=condocompare-docs

# Backend
BACKEND_PORT=8080
JWT_SECRET=your_jwt_secret_here_min_256_bits
JWT_EXPIRATION=86400000

# IA Service
IA_SERVICE_PORT=8000
OPENAI_API_KEY=your_openai_api_key_here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_IA_URL=http://localhost:8000/api/v1

# Environment
SPRING_PROFILES_ACTIVE=dev
NODE_ENV=development
